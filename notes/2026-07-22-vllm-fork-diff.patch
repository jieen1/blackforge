+def _log_and_call_cutedsl_compile(compile_fn, *args, **kwargs):
+    kernel = args[0] if args else kwargs.get("function")
+    kernel_name = getattr(kernel, "__name__", None)
+    if kernel_name is None:
+        kernel_name = kernel.__class__.__name__ if kernel is not None else "<unknown>"
+    _log_cutedsl_jit_compile(kernel_name)
+    return compile_fn(*args, **kwargs)
+
+
+class _MonitoredCuteCompile:
+    """Proxies ``cutlass.cute.compile`` for JIT-compile monitoring.
+
+    ``cute.compile`` supports two call forms: the plain ``compile(fn, ...)``
+    form, and a subscript form ``compile[options](fn, ...)`` used by some
+    CuTe-DSL kernels to bind compile options ahead of the call (e.g.
+    FlashInfer's SM120 GDN prefill kernel, see
+    ``flashinfer/gdn_kernels/delta_rule_dsl/custom_compile_cache.py``).
+    A plain ``@functools.wraps``-wrapped function only supports the first
+    form — subscripting it raises ``TypeError: 'function' object is not
+    subscriptable``. This proxy implements both ``__call__`` and
+    ``__getitem__`` so monitoring doesn't drop the subscript form.
+    """
+
+    def __init__(self, original_compile):
+        self._original_compile = original_compile
+        functools.update_wrapper(
+            self, original_compile, updated=(), assigned=("__doc__",)
+        )
+        self.__name__ = getattr(original_compile, "__name__", "compile")
+
+    def __call__(self, *args, **kwargs):
+        return _log_and_call_cutedsl_compile(self._original_compile, *args, **kwargs)
+
+    def __getitem__(self, key):
+        specialized = self._original_compile[key]
+        return functools.partial(_log_and_call_cutedsl_compile, specialized)
+
+
